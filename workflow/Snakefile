import os
import yaml
import glob


# Load config file
configfile: os.environ.get("SNAKEMAKE_CONFIG", "config/github.config.yaml")

output_dir = config.get("output_dir", "Output")

# List of all individuals from the configuration file
individuals = config["individuals"].keys()

# Only use untreated condition
condition_name = "untreated"

# Labels available under untreated for each individual
labels = {
    ind: list(config["individuals"][ind][condition_name].keys())
    for ind in individuals
    if condition_name in config["individuals"][ind]
    and isinstance(config["individuals"][ind][condition_name], dict)
    and len(config["individuals"][ind][condition_name]) > 0
}

# Valid combinations of individual + label
combinations = []
for ind in labels:
    for lbl in labels[ind]:
        files = config["individuals"][ind][condition_name][lbl]
        if isinstance(files, list) and len(files) > 0:
            combinations.append({"individual": ind, "label": lbl})

wildcard_constraints:
    individual="|".join(sorted(labels.keys())),
    label="|".join(
        sorted(set(lbl for ind in labels for lbl in labels[ind]))
    ),

include: "rules/common.smk"

combinations_dict = {
    "individual": [c["individual"] for c in combinations],
    "label": [c["label"] for c in combinations],
}


def get_merge_input_untreated(wildcards):
    return config["individuals"][wildcards.individual][condition_name][wildcards.label]


rule all:
    input:
        expand(
            "aligned/{individual}_{label}_modified_aligned.bam",
            zip,
            **combinations_dict,
        ),
        expand(
            "aligned/{individual}_{label}_modified_aligned.bam.bai",
            zip,
            **combinations_dict,
        ),
        expand(
            "collapse/collapsed.gff",
            zip,
            **combinations_dict,
        ),
        expand(
            "collapse/collapsed.abundance.txt",
            zip,
            **combinations_dict,
        ),
        expand(
            "collapse//collapsed.read_stat.txt",
            zip,
            **combinations_dict,
        ),
        expand(
            "collapse/collapsed.flnc_count.txt",
            zip,
            **combinations_dict,
        ),
        expand(
            "pigeon/collapsed.prepared.gff",
            zip,
            **combinations_dict,
        ),
        expand(
            "pigeon/pigeon_classification.txt",
            zip,
            **combinations_dict,
        ),
        expand(
            "pigeon/saturation.txt",
            zip,
            **combinations_dict,
        ),


rule merge_individual_label:
    conda:
        "envs/env.yml"
    input:
        get_merge_input_untreated,
    log:
        "logs/merge_individual_label/{individual}_{label}_merged.log",
    output:
        bam="merged/{individual}_{label}_merged.bam",
    threads: config.get("threads", 4)
    resources:
        runtime=930,
    params:
        max_reads=config["max_reads"],
        downsample_reads=config["downsample_reads"],
    benchmark:
        "benchmark/merge_individual_label/{individual}_{label}.txt"
    shell:
        r"""
        exec &> >(tee -a {log})
        set -euo pipefail

        input_files=({input})
        num_files=${{#input_files[@]}}

        if [ $num_files -eq 1 ]; then
            cp {input} {output.bam}
        else
            samtools merge -@ {threads} {output.bam} {input}
        fi

        echo "Merged BAM written to {output.bam}"
        """


rule downsample_individual_label:
    conda:
        "envs/env.yml"
    input:
        bam="merged/{individual}_{label}_merged.bam",
    output:
        bam="merged/{individual}_{label}_merged_capped.bam",
        bai="merged/{individual}_{label}_merged_capped.bam.bai",
    log:
        "logs/downsample_individual_label/{individual}_{label}_downsample.log",
    threads: config.get("threads", 8)
    resources:
        runtime=930,
    params:
        max_reads=config["max_reads"],
        downsample_reads=config["downsample_reads"],
    benchmark:
        "benchmark/downsample_individual_label/{individual}_{label}.txt"
    shell:
        r"""
        exec &> >(tee -a {log})
        set -euo pipefail

        max_reads={params.max_reads}
        keep_reads={params.downsample_reads}

        echo "Counting total reads in {input.bam}..."
        total_reads=$(samtools view -@ {threads} -c {input.bam})
        echo "Total reads: $total_reads"

        mkdir -p $(dirname {output.bam})
        tmpdir=$(mktemp -d)
        trap "rm -rf $tmpdir" EXIT

        if (( total_reads > max_reads )); then
            echo "Threshold ($max_reads) exceeded. Downsampling to exactly $keep_reads reads using QNAME list..."

            samtools view -@ {threads} {input.bam} | awk '{{print $1}}' > $tmpdir/all.qnames
            shuf $tmpdir/all.qnames | head -n "$keep_reads" > $tmpdir/keep.qnames
            samtools view -@ {threads} -N $tmpdir/keep.qnames -b {input.bam} > {output.bam}
            samtools index {output.bam} {output.bai}

            kept=$(samtools view -@ {threads} -c {output.bam})
            echo "Downsampling done. Kept reads: $kept"

            if (( kept != keep_reads )); then
                echo "WARNING: kept ($kept) != requested ($keep_reads). This can happen if QNAMEs are not unique or multi-mapped handling differs."
            fi
        else
            echo "Below or equal to threshold ($max_reads). No downsampling — copying through."
            cp {input.bam} {output.bam}
            samtools index {output.bam} {output.bai}
        fi
        """


rule label_reads:
    conda:
        "envs/env.yml"
    input:
        bam="merged/{individual}_{label}_merged_capped.bam",
    output:
        bam="merged/{individual}_{label}_labeled.bam",
    log:
        "logs/label_reads/{individual}_{label}_labeled.log",
    benchmark:
        "benchmark/label_reads/{individual}_{label}.txt"
    threads: config.get("threads", 4)
    resources:
        runtime=930,
    shell:
        """
        exec &> >(tee -a {log})
        set -euo pipefail

        samtools view -@ {threads} -h {input.bam} | \
        awk -v id="{wildcards.individual}_{wildcards.label}" 'BEGIN {{OFS="\\t"}} !/^@/ {{$1=id"_"$1; print}} /^@/ {{print}}' | \
        samtools view -@ {threads} -o {output.bam}
        """


rule align_sample:
    conda:
        "envs/env.yml"
    input:
        reference=ancient(config["reference_genome"]),
        bam="merged/{individual}_{label}_labeled.bam",
    output:
        aligned="aligned/{individual}_{label}_aligned.bam",
        bai="aligned/{individual}_{label}_aligned.bam.bai",
    log:
        "logs/align_sample/{individual}_{label}_aligned.log",
    threads: config.get("threads", 4)
    resources:
        runtime=930,
        mem_mb=76800,
    benchmark:
        "benchmark/align_samples/{individual}_{label}.txt"
    shell:
        """
        exec &> >(tee -a {log})
        set -euo pipefail

        pbmm2 align \
            --preset ISOSEQ --sort -j {threads} --sort-memory 4G --log-level INFO \
            {input.reference} {input.bam} {output.aligned}
        """


rule modify_rg:
    conda:
        "envs/env.yml"
    input:
        bam="aligned/{individual}_{label}_aligned.bam",
        bai="aligned/{individual}_{label}_aligned.bam.bai",
    output:
        bam="aligned/{individual}_{label}_modified_aligned.bam",
        bai="aligned/{individual}_{label}_modified_aligned.bam.bai",
    log:
        "logs/modify_rg/{individual}_{label}_mod_aligned.log",
    threads: config.get("threads", 4)
    benchmark:
        "benchmark/modify_rg/{individual}_{label}_rg.txt"
    resources:
        runtime=530,
    shell:
        """
        exec &> >(tee -a {log})
        set -euo pipefail

        samtools addreplacerg -@ {threads} \
            -r '@RG\\tID:rg1\\tSM:UnnamedSample\\tLB:lib1\\tPL:PACBIO' \
            --write-index -o {output.bam}##idx##{output.bai} \
            {input.bam}
        """


rule collapse:
    conda:
        "envs/env2.yml"
    input:
        bam="aligned/{individual}_{label}_modified_aligned.bam",
        bai="aligned/{individual}_{label}_modified_aligned.bam.bai",
    output:
        collapsed_gff="collapse/collapsed.gff",
        collapsed_abundance="collapse/collapsed.abundance.txt",
        collapsed_readstat="collapse/collapsed.read_stat.txt",
        collapsed_count="collapse/collapsed.flnc_count.txt",
    log:
        "logs/collapse/{individual}_{label}.log",
    threads: config.get("threads", 4)
    resources:
        runtime=930,
        mem_mb=20530,
    benchmark:
        "benchmark/collapse/{individual}_{label}.txt"
    shell:
        """
        exec &> >(tee -a {log})
        set -euo pipefail

        mkdir -p collapse/{wildcards.individual}_{wildcards.label}

        isoseq collapse --do-not-collapse-extra-5exons --num-threads {threads} \
            {input.bam} {output.collapsed_gff}
        """


rule pigeon_prepare_annot:
    conda:
        "envs/env2.yml"
    input:
        gtf=config["pigeon_annot"],
        collapsed_gff="collapse/collapsed.gff",
    output:
        gtf="annotations/annotations.sorted.gtf",
        pgi="annotations/annotations.sorted.gtf.pgi",
        prepared_collapsed="pigeon/collapsed.prepared.gff",
        prepared_collapsed_pgi="pigeon/collapsed.prepared.gff.pgi",
    params:
        script=workflow.source_path("scripts/clean_pigeon_gtf.awk"),
    log:
        "logs/pigeon_prepare_annot/{individual}_{label}.log",
    benchmark:
        "benchmark/pigeon_prepare/{individual}_{label}.txt"
    shell:
        r"""
        exec &> >(tee -a {log})
        set -euo pipefail

        mkdir -p annotations

        raw_gtf="annotations/annotations.raw.gtf"
        clean_gtf="annotations/annotations.clean.gtf"

        if file {input.gtf} | grep -q 'gzip compressed'; then
            gunzip -c {input.gtf} > "$raw_gtf"
        else
            cp {input.gtf} "$raw_gtf"
        fi

        awk -f {params.script} "$raw_gtf" > "$clean_gtf"

        pigeon prepare "$clean_gtf"
        mv annotations/annotations.clean.sorted.gtf {output.gtf}
        mv annotations/annotations.clean.sorted.gtf.pgi {output.pgi}

        cp {input.collapsed_gff} {output.prepared_collapsed}
        pigeon prepare {output.prepared_collapsed}

        rm -f "$raw_gtf" "$clean_gtf"
        """


rule pigeon_process:
    conda:
        "envs/env2.yml"
    input:
        prepared_collapsed="pigeon/collapsed.prepared.gff",
        collapsed_count="collapse/collapsed.flnc_count.txt",
        prepared_gtf="annotations/annotations.sorted.gtf",
        prepared_index="annotations/annotations.sorted.gtf.pgi",
    output:
        classification="pigeon/pigeon_classification.txt",
        report="pigeon/saturation.txt",
    log:
        "logs/pigeon_process/{individual}_{label}.log",
    params:
        reference=config["reference_genome"],
        outdir=lambda wildcards: f"pigeon/{wildcards.individual}_{wildcards.label}",
        prefix=lambda wildcards: f"{wildcards.individual}_{wildcards.label}",
    benchmark:
        "benchmark/pigeon_process/{individual}_{label}.txt"
    threads: config.get("threads", 4)
    resources:
        runtime=530,
        mem_mb=76800,
    shell:
        """
        exec &> >(tee -a {log})
        set -euo pipefail

        pigeon classify {input.prepared_collapsed} {input.prepared_gtf} {params.reference} \
            --flnc {input.collapsed_count} -d {params.outdir} -o {params.prefix}

        pigeon filter {output.classification}
        pigeon report {params.outdir}/{params.prefix}.filtered_lite_classification.txt {output.report}
        """
